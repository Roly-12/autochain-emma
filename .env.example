APP_NAME="AutoChain Emma+"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

AUTOCHAIN_ADMIN_NAME="Super Admin"
AUTOCHAIN_ADMIN_EMAIL=
AUTOCHAIN_ADMIN_PASSWORD=

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=autochain_emma
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@autochain.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Stockage local par défaut ; utiliser les disques Supabase sur Render.
MEDIA_DISK=public
DOCUMENTS_DISK=local
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_REGION=eu-west-1
SUPABASE_STORAGE_ENDPOINT=https://aadgjifomyxkhzljydp.storage.supabase.co/storage/v1/s3
SUPABASE_MEDIA_BUCKET=autochain-public
SUPABASE_DOCUMENTS_BUCKET=autochain-private
SUPABASE_MEDIA_URL=https://aadgjifomyxkhzljydp.supabase.co/storage/v1/object/public/autochain-public

# IPFS (Kubo local ou gateway Pinata)
IPFS_ENABLED=false
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs

# Blockchain (voir config/blockchain.php)
BLOCKCHAIN_NODE_URL=http://127.0.0.1:8545
BLOCKCHAIN_NETWORK=hardhat
BLOCKCHAIN_CHAIN_ID=31337
BLOCKCHAIN_LOAD_DEPLOYMENT_FILE=true
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_ADMIN_ADDRESS=
VEHICLE_REGISTRY_ABI=
BLOCKCHAIN_TIMEOUT=30

VITE_APP_NAME="${APP_NAME}"
